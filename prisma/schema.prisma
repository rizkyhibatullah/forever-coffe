generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  kasir
}

enum PaymentMethod {
  cash
  qris
}

enum TransactionStatus {
  pending
  paid
}

enum StockLogType {
  in
  out
  sale
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         Role          @default(kasir)
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]
  stockLogs    StockLog[]
  categories   Category[]

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  type      String
  createdBy String    @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  products  Product[]
  user      User      @relation(fields: [createdBy], references: [id])

  @@map("categories")
}

model Product {
  id             String        @id @default(cuid())
  name           String
  description    String?
  price          Float
  costPrice      Float         @map("cost_price")
  imageUrl       String?       @map("image_url")
  categoryId     String        @map("category_id")
  stockQty       Int           @default(0) @map("stock_qty")
  minStockAlert  Int           @default(5) @map("min_stock_alert")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  category       Category      @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  orderItems     OrderItem[]
  stockLogs      StockLog[]

  @@map("products")
}

model StockLog {
  id        String        @id @default(cuid())
  productId String        @map("product_id")
  changeQty Int           @map("change_qty")
  type      StockLogType
  reason    String?
  createdBy String        @map("created_by")
  createdAt DateTime      @default(now()) @map("created_at")
  product   Product       @relation(fields: [productId], references: [id])
  user      User          @relation(fields: [createdBy], references: [id])

  @@map("stock_logs")
}

model Transaction {
  id            String             @id @default(cuid())
  invoiceNo     String             @unique @map("invoice_no")
  cashierId     String             @map("cashier_id")
  paymentMethod PaymentMethod      @map("payment_method")
  subtotal      Float
  discount      Float              @default(0)
  total         Float
  status        TransactionStatus  @default(pending)
  createdAt     DateTime           @default(now()) @map("created_at")
  cashier       User               @relation(fields: [cashierId], references: [id])
  items         TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  productId     String      @map("product_id")
  qty           Int
  priceAtSale   Float       @map("price_at_sale")
  subtotal      Float
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

enum OrderStatus {
  pending
  confirmed
  done
}

model Order {
  id            String       @id @default(cuid())
  customerName  String       @map("customer_name")
  tableNumber   Int?         @map("table_number")
  notes         String?
  status        OrderStatus  @default(pending)
  createdAt     DateTime     @default(now()) @map("created_at")
  items         OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  qty         Int
  priceAtOrder Float  @map("price_at_order")
  subtotal    Float
  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Setting {
  id          String @id @default("default")
  qrisImageUrl String? @map("qris_image_url")
  cafeName    String  @default("Forever Caffe") @map("cafe_name")
  cafeLogo    String? @map("cafe_logo")
  taxPercentage Float @default(0) @map("tax_percentage")

  @@map("settings")
}
